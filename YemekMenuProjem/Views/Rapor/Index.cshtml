@model IEnumerable<YemekMenuProjem.Models.Masa>
@{
    Layout = null;
    var sonRezervasyonlar = ViewBag.SonRezervasyonlar as List<YemekMenuProjem.Models.Rezervasyon>;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Raporlar</title>

    <link href="~/admintemplate/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <style>
        body {
        background-color: #f5f6fa;
        }

        .report-card {
        border: none;
        border-radius: 20px;
        color: #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,.12);
        transition: .3s;
        overflow: hidden;
        }

        .report-card:hover {
        transform: translateY(-5px);
        }

        .report-title {
        font-size: 14px;
        opacity: .85;
        }

        .report-number {
        font-size: 30px;
        font-weight: 700;
        }

        .report-icon {
        font-size: 36px;
        opacity: .7;
        }

        .chart-card, .table-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        }

        .card-header {
        border-bottom: 1px solid #eee;
        border-radius: 20px 20px 0 0 !important;
        }
    </style>
</head>

<body class="sb-nav-fixed">

    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">
        <a class="navbar-brand ps-3" href="#">Food World</a>
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
    </nav>

    <div id="layoutSidenav">

        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark">
                <div class="sb-sidenav-menu">
                    <div class="nav">

                        <div class="sb-sidenav-menu-heading">Dashboard Düzenlemeleri</div>

                        <a class="nav-link" href="@Url.Action("AdminMenu", "Menu")">
                            <div class="sb-nav-link-icon"><i class="fas fa-utensils"></i></div>
                            Menü İşlemleri
                        </a>

                        <a class="nav-link" href="@Url.Action("Index", "Category")">
                            <div class="sb-nav-link-icon"><i class="fas fa-list"></i></div>
                            Kategori İşlemleri
                        </a>

                        <a class="nav-link" href="@Url.Action("Index", "Rezervasyon")">
                            <div class="sb-nav-link-icon"><i class="fas fa-calendar-check"></i></div>
                            Rezervasyon İşlemleri
                        </a>

                        <a class="nav-link" href="@Url.Action("Index", "Masa")">
                            <div class="sb-nav-link-icon"><i class="fas fa-chair"></i></div>
                            Masa İşlemleri
                        </a>

                        <a class="nav-link active" href="@Url.Action("Index", "Rapor")">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-line"></i></div>
                            Rapor İşlemleri
                        </a>

                    </div>
                </div>

                <div class="sb-sidenav-footer">
                    Food World
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">

                    <h1 class="mt-4 fw-bold">Raporlar</h1>
                    <p class="text-muted mb-4">Restoran rezervasyon ve masa durum raporları</p>

                    <div class="row g-4">

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-primary">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Toplam Rezervasyon</div>
                                        <div class="report-number">@ViewBag.ToplamRezervasyon</div>
                                    </div>
                                    <i class="fas fa-calendar-check report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-warning">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Toplam Masa</div>
                                        <div class="report-number">@ViewBag.ToplamMasa</div>
                                    </div>
                                    <i class="fas fa-chair report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-success">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Müsait Masa</div>
                                        <div class="report-number">@ViewBag.MusaitMasa</div>
                                    </div>
                                    <i class="fas fa-check-circle report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-danger">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Dolu Masa</div>
                                        <div class="report-number">@ViewBag.DoluMasa</div>
                                    </div>
                                    <i class="fas fa-times-circle report-icon"></i>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-4 mt-1">

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-dark">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Bugünkü Rezervasyon</div>
                                        <div class="report-number">@ViewBag.BugunkuRezervasyon</div>
                                    </div>
                                    <i class="fas fa-clock report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card bg-info">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Bugünkü Toplam Kişi</div>
                                        <div class="report-number">@ViewBag.BugunkuKisi</div>
                                    </div>
                                    <i class="fas fa-users report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card" style="background: linear-gradient(135deg, #6f42c1, #9b59b6);">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">Ortalama Kişi</div>
                                        <div class="report-number">@ViewBag.OrtalamaKisi</div>
                                    </div>
                                    <i class="fas fa-user-friends report-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card report-card" style="background: linear-gradient(135deg, #ff7e5f, #feb47b);">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="report-title">En Popüler Masa</div>
                                        <div class="report-number">@ViewBag.EnCokRezervasyonAlanMasa</div>
                                    </div>
                                    <i class="fas fa-star report-icon"></i>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-4 mt-3">

                        <div class="col-xl-8">
                            <div class="card chart-card">
                                <div class="card-header bg-white fw-bold">
                                    <i class="fas fa-chart-line me-2"></i>
                                    Günlere Göre Rezervasyon Sayısı
                                </div>
                                <div class="card-body">
                                    <canvas id="myAreaChart" height="110"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-4">
                            <div class="card chart-card">
                                <div class="card-header bg-white fw-bold">
                                    <i class="fas fa-chart-pie me-2"></i>
                                    Masa Doluluk Durumu
                                </div>
                                <div class="card-body">
                                    <canvas id="masaPieChart" height="260"></canvas>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-4 mt-3 mb-4">

                        <div class="col-xl-6">
                            <div class="card chart-card">
                                <div class="card-header bg-white fw-bold">
                                    <i class="fas fa-chart-bar me-2"></i>
                                    Masalara Göre Rezervasyon Sayısı
                                </div>
                                <div class="card-body">
                                    <canvas id="myBarChart" height="180"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-6">
                            <div class="card table-card">
                                <div class="card-header bg-white fw-bold">
                                    <i class="fas fa-list me-2"></i>
                                    Son 5 Rezervasyon
                                </div>

                                <div class="card-body">
                                    <table class="table table-hover align-middle">
                                        <thead>
                                            <tr>
                                                <th>Müşteri</th>
                                                <th>Masa</th>
                                                <th>Tarih</th>
                                                <th>Kişi</th>
                                                <th>Telefon</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @if (sonRezervasyonlar != null && sonRezervasyonlar.Any())
                                            {
                                                foreach (var item in sonRezervasyonlar)
                                                {
                                                    <tr>
                                                        <td>@item.MusteriAdSoyad</td>
                                                        <td>Masa @item.Masa.MasaNo</td>
                                                        <td>@item.RezervasyonTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                                        <td>@item.KisiSayisi</td>
                                                        <td>@item.Telefon</td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="5" class="text-center text-muted">
                                                        Henüz rezervasyon bulunmuyor.
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>

                    </div>

                </div>
            </main>

            <footer class="py-4 bg-light mt-auto">
                <div class="container-fluid px-4">
                    <div class="text-muted small">
                        Copyright &copy; Food World 2026
                    </div>
                </div>
            </footer>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/admintemplate/js/scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const gunlukLabels = @Html.Raw(ViewBag.GunlukTarihler);
        const gunlukData = @Html.Raw(ViewBag.GunlukSayilar);

        new Chart(document.getElementById('myAreaChart'), {
        type: 'line',
        data: {
        labels: gunlukLabels,
        datasets: [{
        label: 'Rezervasyon Sayısı',
        data: gunlukData,
        borderWidth: 3,
        fill: true,
        tension: 0.4
        }]
        }
        });

        const masaLabels = @Html.Raw(ViewBag.MasaNolar);
        const masaData = @Html.Raw(ViewBag.MasaSayilar);

        new Chart(document.getElementById('myBarChart'), {
        type: 'bar',
        data: {
        labels: masaLabels,
        datasets: [{
        label: 'Rezervasyon Sayısı',
        data: masaData,
        borderWidth: 1
        }]
        }
        });

        new Chart(document.getElementById('masaPieChart'), {
        type: 'doughnut',
        data: {
        labels: ['Müsait Masa', 'Dolu Masa'],
        datasets: [{
        data: [@ViewBag.MusaitMasa, @ViewBag.DoluMasa],
        borderWidth: 1
        }]
        }
        });
    </script>

</body>
</html>